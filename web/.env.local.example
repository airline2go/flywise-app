# Copy to .env.local for local development. Not committed (see .gitignore).

# flywise-server's public API base — same env var name/default as the old
# build/generate-pages.js used, for continuity.
API_BASE=https://api.airpiv.com

# Shared secret checked by app/api/revalidate/route.js — must match
# flywise-server's NEXTJS_REVALIDATE_SECRET env var (Phase 2 on-demand
# revalidation). Generate a random string for production.
REVALIDATE_SECRET=

# Browser-side (Phase B, booking/search app) — NEXT_PUBLIC_ prefix
# required since lib/booking-api.js and lib/supabaseClient.js run
# client-side. Both default to the real public values (same Supabase
# project + anon/publishable key, same flywise-server URL, already
# public in the old app's checked-in config.js) if left unset, so this
# section only needs to be touched to point at a different environment.
NEXT_PUBLIC_API_BASE=https://api.airpiv.com
NEXT_PUBLIC_SUPABASE_URL=https://tflpaysskecpmdpwbvog.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ZXi_Rq2zYQIj3LJoNFRctQ_eZogIGD0
